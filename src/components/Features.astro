---
const cards = [
  {
    title: 'Alphabet\nExplorer',
    bg:    '#EDEDF5',
    screenshot: '/screenshots/screen-alphabet.png',
    alt:   'Alphabet Explorer — Hebrew letters grid',
    icon:  '◎',
  },
  {
    title: 'Structured\nLessons',
    bg:    '#E8E4F5',
    screenshot: '/screenshots/screen-lessons.png',
    alt:   'Alphabet Lessons — progress and lesson list',
    icon:  '▣',
  },
  {
    title: 'Reading\nTrainer',
    bg:    '#1F2937',
    screenshot: '/screenshots/screen-reading.png',
    alt:   'Reading Trainer — Hebrew stories',
    icon:  '◈',
    dark:  true,
  },
];
---

<section id="features" class="features-section">
  <div class="container">

    <!-- Intro row — как в референсе -->
    <div class="features-intro">
      <p class="intro-left">
        HebrewEdu offers structured alphabet learning, step-by-step lessons,
        and real Hebrew reading practice — all in one app.
      </p>
      <div class="intro-right">
        <a href="#how-it-works" class="intro-arrow" aria-label="How it works">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </a>
        <h2 class="intro-heading">
          Structured learning,<br/>real results
        </h2>
      </div>
    </div>

    <!-- Three cards -->
    <div class="features-grid">
      {cards.map(c => (
        <div class="fcard" style={`background: ${c.bg};`}>
          <!-- Icon top-right -->
          <div class={`fcard-icon ${c.dark ? 'fcard-icon--dark' : ''}`}>
            <span>{c.icon}</span>
          </div>

          <!-- Title bottom-right -->
          <div class={`fcard-title ${c.dark ? 'fcard-title--dark' : ''}`}>
            {c.title.split('\n').map((line: string) => <span>{line}<br/></span>)}
          </div>

          <!-- Screenshot bottom-left, peeks from bottom -->
          <div class="fcard-screen">
            <img
              src={c.screenshot}
              alt={c.alt}
              class="fcard-img"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.features-section {
  background: #f8f8f6;
  padding-block: var(--space-2xl);
}

/* ── Intro row ── */
.features-intro {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 2rem;
  align-items: end;
  margin-bottom: 4rem;
}

.intro-left {
  font-size: 0.9375rem;
  color: var(--ink-light);
  line-height: 1.7;
  max-width: 320px;
}

.intro-right {
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  gap: 1rem;
}

.intro-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--ink);
  color: white;
  flex-shrink: 0;
  margin-top: 6px;
  transition: transform 0.2s, background 0.2s;
}
.intro-arrow:hover { background: var(--brand); transform: translateY(2px); }

.intro-heading {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3.5vw, 2.625rem);
  font-weight: 800;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: var(--ink);
}

/* ── Cards grid ── */
.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  align-items: stretch;
}

/* ── Single card ── */
.fcard {
  border-radius: 24px;
  overflow: hidden;
  position: relative;
  min-height: 380px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: transform 0.2s, box-shadow 0.2s;
}
.fcard:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.10);
}

/* Icon — top right */
.fcard-icon {
  position: absolute;
  top: 1.25rem;
  right: 1.25rem;
  z-index: 2;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.125rem;
  color: var(--ink);
  box-shadow: 0 2px 8px rgba(0,0,0,.08);
}
.fcard-icon--dark {
  background: rgba(255,255,255,0.15);
  color: white;
  box-shadow: none;
}

/* Title — bottom right */
.fcard-title {
  position: absolute;
  bottom: 1.375rem;
  right: 1.375rem;
  z-index: 2;
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  line-height: 1.2;
  color: var(--ink);
  text-align: right;
}
.fcard-title--dark { color: white; }

/* Screenshot — bottom left, peeks up */
.fcard-screen {
  position: absolute;
  bottom: 0;
  left: 1.25rem;
  z-index: 1;
  width: 55%;
}
.fcard-img {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 16px 16px 0 0;
  object-fit: cover;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.10);
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .features-intro { grid-template-columns: 1fr; }
  .intro-left { max-width: 100%; }
  .features-grid { grid-template-columns: 1fr; max-width: 420px; margin-inline: auto; }
  .fcard { min-height: 320px; }
}
</style>
