---
const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';
---

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');
  :root {
    --font-display: 'Manrope', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-body:    'Manrope', -apple-system, BlinkMacSystemFont, sans-serif;
  }
</style>

<section class="hero">
  <div class="hero-inner container">



    <!-- Pre-title pill -->
    <div class="pretitle animate-in">
      Hebrew Alphabet App for Android
    </div>

    <!-- H1 — главный ключ -->
    <h1 class="hero-title animate-in delay-1">
      Learn the Hebrew Alphabet —<br/>
      from <em class="hero-accent">Aleph Bet</em><br/>
      to confident reading
    </h1>

    <!-- Subtitle — secondary keywords -->
    <p class="hero-subtitle animate-in delay-2">
      The easiest Hebrew alphabet app for beginners. Master all 22 Hebrew letters
      with audio lessons, reading practice, and vocabulary exercises — free on Android.
    </p>

    <!-- Google Play official badge -->
    <div class="hero-actions animate-in delay-3">
      <a href={PLAY_URL} target="_blank" rel="noopener" class="badge-link" aria-label="Get it on Google Play">
        <img
          src="/googleplay-badge.svg"
          alt="Get it on Google Play"
          class="badge-img"
          width="200"
          height="59"
        />
      </a>
    </div>

    
  </div>

</section>

<style>
/* ── Section ── */
.hero {
  position: relative;
  overflow: hidden;
  padding-top: 4rem;
  padding-bottom: 5rem;
  background: #f8f8f6;
}

/* ── Blobs ── */
.hero-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
  z-index: 0;
}
.hero-blob-1 {
  width: 640px; height: 640px;
  background: radial-gradient(circle, rgba(99,102,241,0.11) 0%, transparent 70%);
  top: -120px; left: -180px;
}
.hero-blob-2 {
  width: 520px; height: 520px;
  background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 70%);
  top: 80px; right: -120px;
}

/* ── Inner — flex column, centered ── */
.hero-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}



/* ── Pre-title pill ── */
.pretitle {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.4rem 1.125rem;
  border: 1px solid var(--border-dark);
  border-radius: var(--r-full);
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--ink-light);
  background: white;
  margin-bottom: 1.75rem;
  letter-spacing: 0.01em;
  z-index: 3;
}


/* ── Title ── */
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.75rem, 6vw, 4.375rem);
  font-weight: 800;
  line-height: 1.07;
  letter-spacing: -0.03em;
  color: var(--ink);
  max-width: 860px;
  margin-bottom: 1.375rem;
  z-index: 3;
}
.hero-accent {
  font-style: normal;
  color: #F59E0B;
}

/* ── Subtitle ── */
.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.125rem);
  font-weight: 400;
  color: var(--ink-light);
  line-height: 1.7;
  max-width: 540px;
  margin-bottom: 2rem;
  z-index: 3;
}

/* ── Badge ── */
.hero-actions {
  margin-bottom: 3rem;
  z-index: 3;
}
.badge-link {
  display: inline-block;
  transition: transform 0.15s, opacity 0.15s;
}
.badge-link:hover { transform: translateY(-2px); opacity: 0.9; }
.badge-img {
  height: 56px;
  width: auto;
  display: block;
}

/* ── Phone screenshot ── */
.phone-wrap {
  position: relative;
  z-index: 3;
}
.phone-screen {
  display: block;
  width: 300px;
  height: auto;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .letter-bubble { display: none; }
  .phone-frame   { width: 220px; }
}
</style>
