---
const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';

const steps = [
  {
    num: '01',
    title: 'Learn the alphabet',
    desc:  'Start with Aleph Bet lessons — each letter explained with audio, shape, and pronunciation guide.',
  },
  {
    num: '02',
    title: 'Practice with exercises',
    desc:  'Daily exercises, quizzes, and the Alphabet Trainer build recognition and reading speed.',
  },
  {
    num: '03',
    title: 'Build vocabulary',
    desc:  'Hebrew Words and smart review system reinforce essential vocabulary for long-term memory.',
  },
  {
    num: '04',
    title: 'Read real texts',
    desc:  'Graduate to the Reading Trainer — illustrated stories written for beginner Hebrew learners.',
  },
];
---

<section id="how-it-works" class="how-section">
  <div class="container how-grid">
    <!-- Left: steps -->
    <div class="how-text">
      <p class="eyebrow">How it works</p>
      <h2 class="display-lg mt-xs">Simple path<br/>to reading Hebrew</h2>
      <p class="lead mt-sm">
        No overwhelm. No random vocabulary lists. Just a clear, progressive
        path from your very first letter to reading whole sentences.
      </p>

      <ol class="steps-list mt-lg">
        {steps.map(s => (
          <li class="step">
            <div class="step-num">{s.num}</div>
            <div>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Right: phone + CTA -->
    <div class="how-visual">
      <div class="how-phone-wrap">
        <div class="how-phone-frame">
          <div class="phone-notch-sm"></div>
          <img
            src="/screenshots/screen-trainer.jpg"
            alt="Alphabet Trainer Hub showing daily goal, streak, and recommended exercises"
            class="how-screen"
            loading="lazy"
            width="260"
            height="520"
          />
        </div>
        <!-- CTA card floating over phone -->
        <div class="how-cta-card">
          <p class="how-cta-text">Ready to start?</p>
          <a href={PLAY_URL} class="btn btn-primary" target="_blank" rel="noopener" style="font-size:0.875rem; padding: 0.6rem 1.1rem;">
            Download App
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.how-section { background: var(--bg); }

.how-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2rem, 6vw, 5rem);
  align-items: center;
}

/* Steps */
.steps-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }

.step {
  display: flex;
  gap: 1.125rem;
  align-items: flex-start;
}

.step-num {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--brand);
  background: var(--brand-light);
  border-radius: var(--r-sm);
  padding: 0.375rem 0.5rem;
  flex-shrink: 0;
  margin-top: 2px;
  letter-spacing: 0.04em;
}

.step-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 0.25rem;
}
.step-desc { font-size: 0.9rem; color: var(--ink-light); line-height: 1.6; }

/* Phone */
.how-visual { display: flex; justify-content: center; }

.how-phone-wrap { position: relative; width: 290px; height: 580px; }

.how-phone-frame {
  position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 260px;
  background: var(--ink);
  border-radius: 40px;
  padding: 12px 10px;
  box-shadow: var(--shadow-lg), 0 0 0 7px #374151, 0 0 0 9px #1F2937;
}
.phone-notch-sm {
  width: 70px; height: 22px;
  background: var(--ink);
  border-radius: 0 0 16px 16px;
  margin: 0 auto 4px;
}
.how-screen {
  width: 100%;
  border-radius: 26px;
  object-fit: cover;
  display: block;
}

.how-cta-card {
  position: absolute;
  bottom: 0; right: -10px;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 1rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  box-shadow: var(--shadow-md);
  animation: float-card 5s ease-in-out infinite;
}
.how-cta-text { font-size: 0.875rem; color: var(--ink-light); }

@media (max-width: 900px) {
  .how-grid { grid-template-columns: 1fr; }
  .how-visual { display: none; }
}
</style>
