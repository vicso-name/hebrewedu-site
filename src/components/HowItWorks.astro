---
const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';

const steps = [
  {
    num: '01',
    title: 'Learn the alphabet',
    desc:  'Start with Aleph Bet lessons — each letter explained with audio, shape, and pronunciation guide.',
    pos: 'top-center',
  },
  {
    num: '02',
    title: 'Practice with exercises',
    desc:  'Daily exercises, quizzes, and the Alphabet Trainer build recognition and reading speed.',
    pos: 'mid-left',
  },
  {
    num: '03',
    title: 'Build vocabulary',
    desc:  'Hebrew Words and smart review system reinforce essential vocabulary for long-term memory.',
    pos: 'bot-left',
  },
  {
    num: '04',
    title: 'Read real texts',
    desc:  'Graduate to the Reading Trainer — illustrated stories written for beginner Hebrew learners.',
    pos: 'bot-center',
  },
];
---

<section id="how-it-works" class="how-section">
  <!-- Gradient blobs behind the phone -->
  <div class="how-blob how-blob-1" aria-hidden="true"></div>
  <div class="how-blob how-blob-2" aria-hidden="true"></div>

  <div class="container" style="position:relative; z-index:1;">

    <!-- Top row: big title left, description right -->
    <div class="how-header">
      <h2 class="how-title">
        Simple Steps to<br/>
        Learning Hebrew
      </h2>
      <p class="how-desc">
        Discover how easy it is to learn Hebrew with HebrewEdu.
        Our structured approach ensures a smooth, progressive experience
        from your first letter to reading full texts.
      </p>
    </div>

    <!-- Main layout: steps + phone + cta -->
    <div class="how-body">

      <!-- Step cards — positioned around the phone -->
      <div class="steps-field">

        <!-- Step 01 — top center-left -->
        <div class="step-card step-01">
          <div class="step-top">
            <span class="step-title">{steps[0].title}</span>
            <span class="step-num">{steps[0].num}</span>
          </div>
          <p class="step-desc">{steps[0].desc}</p>
        </div>

        <!-- Step 02 — mid left -->
        <div class="step-card step-02">
          <div class="step-top">
            <span class="step-title">{steps[1].title}</span>
            <span class="step-num">{steps[1].num}</span>
          </div>
          <p class="step-desc">{steps[1].desc}</p>
        </div>

        <!-- Phone — center -->
        <div class="how-phone">
          <img
            src="/screenshots/screen-trainer.png"
            alt="Alphabet Trainer Hub"
            class="how-screen"
            loading="lazy"
          />
        </div>

        <!-- CTA — right of phone -->
        <div class="how-cta">
          <p class="how-cta-text">Start learning Hebrew<br/>from day one.</p>
          <a href={PLAY_URL} class="how-cta-btn" target="_blank" rel="noopener">
            Download App
          </a>
        </div>

        <!-- Step 03 — bot left -->
        <div class="step-card step-03">
          <div class="step-top">
            <span class="step-title">{steps[2].title}</span>
            <span class="step-num">{steps[2].num}</span>
          </div>
          <p class="step-desc">{steps[2].desc}</p>
        </div>

        <!-- Step 04 — bot center-left -->
        <div class="step-card step-04">
          <div class="step-top">
            <span class="step-title">{steps[3].title}</span>
            <span class="step-num">{steps[3].num}</span>
          </div>
          <p class="step-desc">{steps[3].desc}</p>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
.how-section {
  background: #f8f8f6;
  padding-block: var(--space-2xl);
  position: relative;
  overflow: hidden;
}

/* ── Gradient blobs — за телефоном по центру ── */
.how-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  z-index: 0;
}
/* Индиго — левее центра, за телефоном */
.how-blob-1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(99,102,241,0.13) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-60%, -50%);
}
/* Изумрудный — правее центра, за телефоном */
.how-blob-2 {
  width: 420px; height: 420px;
  background: radial-gradient(circle, rgba(16,185,129,0.09) 0%, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-30%, -55%);
}

/* ── Header row ── */
.how-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: end;
  margin-bottom: 5rem;
}

.how-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: var(--ink);
}

.how-desc {
  font-size: 0.9375rem;
  color: var(--ink-light);
  line-height: 1.7;
  max-width: 380px;
  justify-self: end;
}

/* ── Body — CSS grid layout identical to reference ── */
.steps-field {
  display: grid;
  grid-template-columns: 1fr 1fr 320px 1fr;
  grid-template-rows: auto auto;
  gap: 1rem;
  align-items: start;
}

/* Step cards */
.step-card {
  background: white;
  border-radius: 20px;
  padding: 1.375rem 1.25rem;
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}

.step-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 0.5rem;
  margin-bottom: 0.625rem;
}

.step-title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.25;
}

.step-num {
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--ink-subtle);
  background: var(--bg);
  border-radius: 8px;
  padding: 0.2rem 0.5rem;
  flex-shrink: 0;
}

.step-desc {
  font-size: 0.875rem;
  color: var(--ink-light);
  line-height: 1.65;
}

/* Grid positions — reference layout */
.step-01 {
  grid-column: 2;
  grid-row: 1;
}
.step-02 {
  grid-column: 1;
  grid-row: 2;
  align-self: center;
}
.step-03 {
  grid-column: 1;
  grid-row: 3;
}
.step-04 {
  grid-column: 2;
  grid-row: 3;
}

/* Phone — column 3, spans rows */
.how-phone {
  grid-column: 3;
  grid-row: 1 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
}
.how-screen {
  width: 100%;
  max-width: 300px;
  height: auto;
  display: block;
  border-radius: 12px;
}

/* CTA — column 4, row 1-2 */
.how-cta {
  grid-column: 4;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 1.25rem;
  padding-left: 0.5rem;
}

.how-cta-text {
  font-family: var(--font-display);
  font-size: 0.9375rem;
  color: var(--ink-light);
  line-height: 1.6;
}

.how-cta-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.75rem 1.5rem;
  background: var(--ink);
  color: white;
  border-radius: var(--r-full);
  font-family: var(--font-display);
  font-size: 0.9375rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.15s, transform 0.15s;
  box-shadow: 0 4px 16px rgba(31,41,55,0.22);
}
.how-cta-btn:hover {
  background: #111827;
  transform: translateY(-1px);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .steps-field {
    grid-template-columns: 1fr 280px 1fr;
    grid-template-rows: auto auto auto;
  }
  .step-01 { grid-column: 1; grid-row: 1; }
  .step-02 { grid-column: 1; grid-row: 2; }
  .step-03 { grid-column: 3; grid-row: 1; }
  .step-04 { grid-column: 3; grid-row: 2; }
  .how-phone { grid-column: 2; grid-row: 1 / 3; }
  .how-cta { grid-column: 1 / 4; grid-row: 3; flex-direction: row; align-items: center; padding: 1.5rem; background: white; border-radius: 20px; }
}

@media (max-width: 768px) {
  .how-header { grid-template-columns: 1fr; gap: 1rem; }
  .steps-field { display: flex; flex-direction: column; }
  .how-phone { order: -1; }
  .how-cta { width: 100%; }
}
</style>
