---
const reviews = [
  {
    name:   'Sarah M.',
    avatar: 'SM',
    color:  '#6366F1',
    rating: 5,
    text:   'Finally an app that explains Hebrew letters properly. The audio is so clear and the structured lessons make it easy to track my progress.',
  },
  {
    name:   'David K.',
    avatar: 'DK',
    color:  '#10B981',
    rating: 5,
    text:   'I love the Reading Trainer feature. Being able to read actual Hebrew stories, even as a beginner, is incredibly motivating!',
  },
  {
    name:   'Miriam L.',
    avatar: 'ML',
    color:  '#F59E0B',
    rating: 5,
    text:   'The Alphabet Explorer is brilliant. I can see all 22 letters at a glance and the color coding between consonants and special forms is very helpful.',
  },
  {
    name:   'James R.',
    avatar: 'JR',
    color:  '#6366F1',
    rating: 5,
    text:   'Perfect for beginners. I had no idea where to start with Hebrew, but this app guides you step by step. The offline mode is a huge bonus.',
  },
];
---

<section class="testimonials-section">
  <div class="container">
    <div class="testimonials-inner">

      <!-- Left: headline + arrows -->
      <div class="testimonials-header">
        <h2 class="t-title">
          User reviews<br/>and feedback from<br/>real users.
        </h2>
        <div class="slider-arrows">
          <button class="arrow-btn" id="t-prev" aria-label="Previous review">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
          </button>
          <button class="arrow-btn" id="t-next" aria-label="Next review">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Right: slider -->
      <div class="slider-outer">
        <div class="slider-viewport" id="t-viewport">
          <div class="slider-track" id="t-track">
            {reviews.map(r => (
              <div class="review-card">
                <!-- Avatar + name + stars -->
                <div class="review-top">
                  <div class="review-avatar" style={`background: ${r.color}18; color: ${r.color};`}>
                    {r.avatar}
                  </div>
                  <div>
                    <p class="review-name">{r.name}</p>
                    <div class="review-stars">
                      {'★'.repeat(r.rating)}
                    </div>
                  </div>
                </div>
                <!-- Text -->
                <p class="review-text">{r.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.testimonials-section {
  background: #F1F0F5;
  padding-block: var(--space-2xl);
}

.testimonials-inner {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: clamp(2rem, 5vw, 4rem);
  align-items: center;
}

/* ── Left ── */
.t-title {
  font-family: var(--font-display);
  font-size: clamp(1.75rem, 3.5vw, 2.625rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 2rem;
}

.slider-arrows {
  display: flex;
  gap: 0.625rem;
}

.arrow-btn {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1.5px solid var(--border-dark);
  background: white;
  color: var(--ink);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, border-color 0.15s, transform 0.15s;
}
.arrow-btn:hover {
  background: var(--ink);
  color: white;
  border-color: var(--ink);
  transform: scale(1.05);
}

/* ── Slider ── */
.slider-outer {
  overflow: hidden;
}

.slider-viewport {
  padding: 0.5rem 0;
}

.slider-track {
  display: flex;
  gap: 1rem;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: transform;
}

/* ── Review card ── */
.review-card {
  background: white;
  border-radius: 20px;
  padding: 1.625rem 1.5rem;
  width: calc(50% - 0.5rem);
  flex-shrink: 0;
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  margin-bottom: 1rem;
}

.review-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9375rem;
  flex-shrink: 0;
}

.review-name {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1rem;
  color: var(--ink);
  margin-bottom: 0.2rem;
}

.review-stars {
  font-size: 1rem;
  color: var(--amber);
  letter-spacing: 1px;
}

.review-text {
  font-size: 0.9375rem;
  color: var(--ink-light);
  line-height: 1.7;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .testimonials-inner { grid-template-columns: 1fr; }
  .review-card { min-width: calc(85% - 0.5rem); }
}
</style>

<script>
const track   = document.getElementById('t-track')  as HTMLElement;
const prev    = document.getElementById('t-prev')   as HTMLButtonElement;
const next    = document.getElementById('t-next')   as HTMLButtonElement;

let current = 0;

function getVisible() {
  return window.innerWidth < 900 ? 1 : 2;
}

function update() {
  const cards   = Array.from(track.querySelectorAll('.review-card')) as HTMLElement[];
  const visible = getVisible();
  const max     = cards.length - visible;
  current = Math.max(0, Math.min(current, max));

  // Card width = its own offsetWidth + gap (1rem = 16px)
  const gap    = 16;
  const cardW  = cards[0].offsetWidth + gap;
  track.style.transform = `translateX(-${current * cardW}px)`;

  (prev as HTMLElement).style.opacity = current === 0  ? '0.35' : '1';
  (next as HTMLElement).style.opacity = current >= max ? '0.35' : '1';
}

prev.addEventListener('click', () => { current--; update(); });
next.addEventListener('click', () => { current++; update(); });
window.addEventListener('resize', () => { current = 0; update(); });

// Run after paint so offsetWidth is accurate
requestAnimationFrame(update);
</script>
