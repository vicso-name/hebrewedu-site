---
const links = [
  { label: 'Features',    href: '/#features'    },
  { label: 'How it works',href: '/#how-it-works' },
  { label: 'Blog',        href: '/blog'          },
];

const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';
---

<header class="nav-wrap">
  <nav class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="HebrewEdu home">
      <span class="logo-mark">א</span>
      <span class="logo-text">HebrewEdu</span>
    </a>

    <!-- Links -->
    <ul class="nav-links" role="list">
      {links.map(l => (
        <li><a href={l.href} class="nav-link">{l.label}</a></li>
      ))}
    </ul>

    <!-- CTA -->
    <a href={PLAY_URL} class="btn btn-primary nav-cta" target="_blank" rel="noopener">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3.18 23.76a2 2 0 0 1-1.18-1.9V2.14A2 2 0 0 1 3.18.24L14.9 12 3.18 23.76zm2.18-.48 11.36-6.56-2.68-2.68-8.68 9.24zm12.54-7.24L20.78 14a1.5 1.5 0 0 0 0-2.6l-2.88-1.64L14.9 12l3 4.04zM5.36.72l8.68 9.24 2.68-2.68L5.36.72z"/>
      </svg>
      Download App
    </a>

    <!-- Mobile burger -->
    <button class="nav-burger" aria-label="Open menu" id="nav-burger">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    {links.map(l => (
      <a href={l.href} class="nav-mobile-link">{l.label}</a>
    ))}
    <a href={PLAY_URL} class="btn btn-primary" target="_blank" rel="noopener">Download App</a>
  </div>
</header>

<style>
.nav-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(248, 248, 255, 0.85);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 68px;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}
.logo-mark {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--brand);
  line-height: 1;
}
.logo-text {
  font-family: var(--font-display);
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--ink);
}

.nav-links {
  display: flex;
  list-style: none;
  gap: 0.25rem;
  margin-inline-start: auto;
}
.nav-link {
  padding: 0.4rem 0.75rem;
  border-radius: var(--r-sm);
  font-size: 0.9375rem;
  color: var(--ink-light);
  transition: color 0.15s, background 0.15s;
}
.nav-link:hover { color: var(--ink); background: var(--brand-light); }

.nav-cta { padding: 0.55rem 1.25rem; font-size: 0.875rem; margin-inline-start: 0.5rem; }

.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.25rem;
  margin-inline-start: auto;
}
.nav-burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: 0.2s;
}

.nav-mobile {
  display: none;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1rem 1.25rem 1.5rem;
  border-top: 1px solid var(--border);
  background: var(--bg);
}
.nav-mobile-link {
  font-size: 1rem;
  color: var(--ink-light);
  padding: 0.5rem 0;
}
.nav-mobile.open { display: flex; }

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .nav-burger { display: flex; }
}
</style>

<script>
const burger = document.getElementById('nav-burger');
const menu   = document.getElementById('nav-mobile');
burger?.addEventListener('click', () => {
  menu?.classList.toggle('open');
  const isOpen = menu?.classList.contains('open');
  menu?.setAttribute('aria-hidden', String(!isOpen));
});
</script>
