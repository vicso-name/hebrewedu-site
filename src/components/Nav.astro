---
const links = [
  { label: 'Features',     href: '/#features'     },
  { label: 'How it works', href: '/#how-it-works'  },
  { label: 'Blog',         href: '/blog'           },
];

const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';
---

<header class="nav-wrap">
  <nav class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="HebrewEdu home">
      HEBREWEDU
    </a>

    <ul class="nav-links" role="list">
      {links.map(l => (
        <li><a href={l.href} class="nav-link">{l.label}</a></li>
      ))}
    </ul>

    <a href={PLAY_URL} class="nav-cta" target="_blank" rel="noopener">
      Download App
    </a>

    <button class="nav-burger" aria-label="Open menu" id="nav-burger" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<!-- Fixed поверх контента — не внутри header -->
<div class="nav-mobile" id="nav-mobile" aria-hidden="true">
  <div class="nav-mobile-inner">
    {links.map(l => (
      <a href={l.href} class="nav-mobile-link">{l.label}</a>
    ))}
    <a href={PLAY_URL} class="nav-mobile-cta" target="_blank" rel="noopener">
      Download App
    </a>
  </div>
</div>

<style>
.nav-wrap {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(248, 248, 246, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.nav-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 68px;
}

.nav-logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--ink-light);
  letter-spacing: 0.06em;
  position: relative;
  padding-bottom: 2px;
  transition: color 0.25s;
}

/* Линия постоянная — цвет совпадает с текстом */
.nav-logo::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 1.5px;
  background: var(--ink-light);
  border-radius: 2px;
  transition: background 0.25s;
}

.nav-logo:hover { color: var(--ink); }
.nav-logo:hover::after { background: var(--ink); }

.nav-links { display: flex; list-style: none; gap: 0.25rem; margin-inline-start: auto; }
.nav-link {
  padding: 0.4rem 0.875rem;
  border-radius: var(--r-full);
  font-size: 0.9375rem;
  color: var(--ink-light);
  transition: color 0.15s, background 0.15s;
}
.nav-link:hover { color: var(--ink); background: var(--brand-light); }

.nav-cta {
  display: inline-flex;
  align-items: center;
  margin-inline-start: 0.5rem;
  padding: 0.55rem 1.375rem;
  background: var(--ink);
  color: white;
  border-radius: var(--r-full);
  font-size: 0.875rem;
  font-weight: 500;
  transition: background 0.15s, transform 0.15s;
  white-space: nowrap;
}
.nav-cta:hover { background: #111827; transform: translateY(-1px); }

/* ── Burger ── */
.nav-burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.375rem;
  margin-inline-start: auto;
  position: relative;
  z-index: 201;
}
.nav-burger span {
  display: block;
  width: 22px; height: 2px;
  background: var(--ink);
  border-radius: 2px;
  transition: transform 0.25s, opacity 0.2s;
  transform-origin: center;
}
/* Анимация в X */
.nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Mobile menu — position fixed, поверх страницы ── */
.nav-mobile {
  position: fixed;
  top: 68px;
  left: 0; right: 0;
  z-index: 190;
  background: rgba(248, 248, 246, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 8px 32px rgba(0,0,0,0.07);

  max-height: 0;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.25s ease;
}
.nav-mobile.open {
  max-height: 320px;
  opacity: 1;
  pointer-events: auto;
}

.nav-mobile-inner {
  display: flex;
  flex-direction: column;
  padding: 1.25rem 1.5rem 1.75rem;
  gap: 0;
}

.nav-mobile-link {
  font-family: var(--font-display);
  font-size: 1.0625rem;
  font-weight: 500;
  color: var(--ink-light);
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
  transition: color 0.15s;
  display: block;
}
.nav-mobile-link:hover { color: var(--ink); }

.nav-mobile-cta {
  display: block;
  margin-top: 1.25rem;
  padding: 0.875rem;
  background: var(--ink);
  color: white;
  border-radius: var(--r-full);
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 500;
  text-align: center;
  transition: background 0.15s;
}
.nav-mobile-cta:hover { background: #111827; }

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .nav-burger { display: flex; }
}
</style>

<script>
const burger = document.getElementById('nav-burger') as HTMLButtonElement;
const menu   = document.getElementById('nav-mobile') as HTMLElement;

function openMenu() {
  menu.classList.add('open');
  burger.classList.add('is-open');
  burger.setAttribute('aria-expanded', 'true');
  menu.setAttribute('aria-hidden', 'false');
}

function closeMenu() {
  menu.classList.remove('open');
  burger.classList.remove('is-open');
  burger.setAttribute('aria-expanded', 'false');
  menu.setAttribute('aria-hidden', 'true');
}

burger?.addEventListener('click', () => {
  menu.classList.contains('open') ? closeMenu() : openMenu();
});

// Закрываем при клике на ссылку
menu?.querySelectorAll('.nav-mobile-link').forEach(link => {
  link.addEventListener('click', closeMenu);
});

// Закрываем при клике вне меню
document.addEventListener('click', (e) => {
  if (!menu.contains(e.target as Node) && !burger.contains(e.target as Node)) {
    closeMenu();
  }
});
</script>
