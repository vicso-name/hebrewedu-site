---
const year = new Date().getFullYear();

const links = [
  { label: 'Features',     href: '/#features'    },
  { label: 'How it works', href: '/#how-it-works' },
  { label: 'Blog',         href: '/blog'          },
  { label: 'Terms',        href: '/terms'         },
  { label: 'Privacy',      href: '/privacy'       },
];

const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';
---

<footer class="footer">
  <div class="container footer-inner">

    <!-- Logo -->
    <a href="/" class="footer-logo" aria-label="HebrewEdu">
      HEBREWEDU
    </a>

    <!-- Nav links — center -->
    <nav class="footer-nav" aria-label="Footer">
      {links.map(l => (
        <a href={l.href} class="footer-link">{l.label}</a>
      ))}
    </nav>

    <!-- Right: Google Play badge -->
    <a href={PLAY_URL} class="footer-badge" target="_blank" rel="noopener" aria-label="Get it on Google Play">
      <img src="/googleplay-badge.svg" alt="Get it on Google Play" height="36" width="auto" />
    </a>

  </div>

  <!-- Bottom line -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">© {year} HebrewEdu. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: #f8f8f6;
  border-top: 1px solid var(--border);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  padding-block: 1.75rem;
  flex-wrap: wrap;
}

.footer-logo {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--ink-light);
  letter-spacing: 0.06em;
  position: relative;
  padding-bottom: 2px;
  transition: color 0.25s;
}
.footer-logo::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  height: 1.5px;
  background: var(--ink-light);
  border-radius: 2px;
  transition: background 0.25s;
}
.footer-logo:hover { color: var(--ink); }
.footer-logo:hover::after { background: var(--ink); }

/* Nav */
.footer-nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
  justify-content: center;
}
.footer-link {
  padding: 0.3rem 0.75rem;
  font-size: 0.9rem;
  color: var(--ink-light);
  border-radius: var(--r-full);
  transition: color 0.15s, background 0.15s;
}
.footer-link:hover { color: var(--ink); background: var(--border); }

/* Badge */
.footer-badge {
  display: inline-block;
  flex-shrink: 0;
  transition: opacity 0.15s, transform 0.15s;
}
.footer-badge:hover { opacity: 0.8; transform: translateY(-1px); }
.footer-badge img { height: 36px; width: auto; display: block; }

/* Bottom */
.footer-bottom { border-top: 1px solid var(--border); }
.footer-bottom-inner {
  padding-block: 1rem;
  display: flex;
  justify-content: center;
}
.footer-copy {
  font-size: 0.8125rem;
  color: var(--ink-subtle);
}

@media (max-width: 768px) {
  .footer-inner { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
  .footer-nav { justify-content: flex-start; }
}
</style>
