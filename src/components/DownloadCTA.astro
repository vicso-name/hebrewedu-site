---
const PLAY_URL = 'https://play.google.com/store/apps/details?id=com.vicsothemes.hebrewforbeginners';
---

<section class="cta-section">
  <div class="container">
    <div class="cta-card">

      <!-- Left: text content -->
      <div class="cta-left">
        <p class="cta-pretitle">Ready to start learning Hebrew?</p>

        <h2 class="cta-title">
          Download
          Hebrew App
        </h2>

        <div class="cta-bottom">
          <a href={PLAY_URL} class="badge-link" target="_blank" rel="noopener" aria-label="Get it on Google Play">
            <img
              src="/googleplay-badge.svg"
              alt="Get it on Google Play"
              class="badge-img"
              width="180"
              height="53"
            />
          </a>
          <p class="cta-desc">
            Download HebrewEdu & start reading<br/>Hebrew from your very first lesson.
          </p>
        </div>
      </div>

      <!-- Right: phone screenshot -->
      <div class="cta-right">
        <img
          src="/screenshots/screen-alphabet.png"
          alt="Alphabet Explorer — Hebrew letters grid"
          class="cta-phone-img"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

<style>
.cta-section {
  background: #f8f8f6;
  padding-block: var(--space-xl) var(--space-2xl);
}

/* ── Rounded card ── */
.cta-card {
  background: #F1F0F5;
  border-radius: 32px;
  overflow: hidden;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: end;
  min-height: 460px;
  position: relative;
}

/* ── Left ── */
.cta-left {
  padding: 3rem 2.5rem 3rem 3rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
}

.cta-pretitle {
  font-family: var(--font-display);
  font-size: 0.9375rem;
  color: var(--ink-light);
  margin-bottom: 1.25rem;
}

.cta-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 3.75rem);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: var(--ink);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: auto;
  max-width: 350px;
}

.cta-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--ink);
  color: white;
  flex-shrink: 0;
  transition: background 0.15s, transform 0.15s;
  align-self: center;
}
.cta-icon-btn:hover {
  background: var(--brand);
  transform: translateY(2px);
}

.cta-bottom {
  margin-top: 2.5rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.badge-link {
  display: inline-block;
  transition: transform 0.15s, opacity 0.15s;
  flex-shrink: 0;
}
.badge-link:hover { transform: translateY(-2px); opacity: 0.9; }
.badge-img { height: 50px; width: auto; display: block; }

.cta-desc {
  font-size: 0.9375rem;
  color: var(--ink-light);
  line-height: 1.6;
}

/* ── Right: phone ── */
.cta-right {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 100%;
  padding-top: 2rem;
}

.cta-phone-img {
  width: 75%;
  max-width: 340px;
  height: auto;
  display: block;
  border-radius: 20px 20px 0 0;
  object-fit: cover;
  /* Slight tilt like in the reference */
  transform: perspective(800px) rotateY(-6deg) rotateX(2deg);
  transform-origin: bottom center;
  box-shadow: -12px 0 40px rgba(0,0,0,0.08);
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .cta-card { grid-template-columns: 1fr; min-height: auto; }
  .cta-right { display: none; }
  .cta-left { padding: 2rem; }
}
</style>
